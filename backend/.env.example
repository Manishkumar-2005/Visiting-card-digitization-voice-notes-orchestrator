# General Config
ENVIRONMENT=development
PORT=8000

# Gemini API (Required for live OCR/Transcription)
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB Atlas URI (If omitted, system automatically falls back to SQLite)
# Example: mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_URI=

# Google Sheets Configuration
# Paste your raw Service Account JSON key string below.
# If omitted, system automatically falls back to local JSON file sheets storage.
GOOGLE_CREDENTIALS_JSON=
GOOGLE_SHEET_NAME=Visiting Cards Orchestrator

# WhatsApp Business API Config
# If any of these are omitted, notifications fallback to a local mock log file.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_RECIPIENT_PHONE=
